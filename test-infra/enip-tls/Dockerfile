# A minimal stunnel TLS terminator for the CIP Security Phase-1 validation peer
# (DESIGN-cip-security.md §5.2). It wraps the cpppo EtherNet/IP tag server in TLS on TCP 2221.
#
# Build context is this directory; the stunnel config is baked in, and the test PKI (generated by
# ./gen-certs.sh) is bind-mounted at /etc/stunnel/certs by compose.yaml — so regenerating certs does
# not require a rebuild.
FROM alpine:3.20

RUN apk add --no-cache stunnel openssl

# Both configs ship in the image; compose selects one per service via the CMD.
COPY stunnel.conf /etc/stunnel/stunnel.conf
COPY stunnel-cbc.conf /etc/stunnel/stunnel-cbc.conf

# GCM/spec-current terminator by default.
CMD ["stunnel", "/etc/stunnel/stunnel.conf"]
